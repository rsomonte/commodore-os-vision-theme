style "section-subheader"
{
   font_name ="LuzSans-Medium 12"
      fg[NORMAL] = "#FFFFFF"
}
widget "*.favorite_websites_label" style "section-subheader"

style "hp-web-entry"
{

  xthickness = 5
  ythickness = 5

  GtkWidget::interior_focus = 1
  text[INSENSITIVE] = "#666"
  text[NORMAL] = "#191919"
  base[NORMAL] = "#282A2B"

  engine "pixmap"
  {

    image
    {
      function = SHADOW
      file = "/harbour/launcher_URL_textfield.png"
      border = { 7 , 7 , 7 , 7 }
      stretch = TRUE
    }
    image
    {
      function = FLAT_BOX
      file = "/harbour/launcher_URL_textfield_inner.png"
      border = { 0, 0, 0, 0 }
      stretch = TRUE
    }
  }
}
widget "*.web_entry" style "hp-web-entry"

style "hp-go-button"
{
  xthickness = 2
  ythickness = 2
  engine "pixmap"
  {
    image
    {
      function = BOX
      state = NORMAL
      file = "/harbour/launcher_URL_button_centre.png"
      border = { 2 , 2 , 2 ,2 }
      stretch = TRUE
    }
    image
    {
      function = BOX
      state = ACTIVE
      file = "/harbour/launcher_URL_button_centre_active.png"
      border = { 7 , 7 , 7 , 7 }
      stretch = TRUE
    }
    image
    {
      function = BOX
      state = PRELIGHT
      file = "/harbour/launcher_URL_button_centre_prelight.png"
      border = { 7 , 7 , 7 , 7 }
      stretch = TRUE
    }
  }
}
widget "*.web_go_button" style "hp-go-button"

style "hp-search-button"
{
  xthickness = 2
  ythickness = 2
  engine "pixmap"
  {

    image
    {
      function = BOX
